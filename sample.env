# Required
MQTT_BROKER=your_mqtt_broker_address
MQTT_USER=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# Optional for calendar/TODO features
CAL_SCRAPER_HOST=your_calendar_scraper_url
TIMEZONE=America/Chicago

# Optional — set to your Signal account number to suppress your own outgoing
# messages from being sent to the LED sign (e.g. +15551234567)
# SIGNAL_OWN_NUMBER=